 Masked text input for secure password entry.</w:t></w:r></w:p><w:p w14:paraId="54C176D5" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Requirement FR-03: Interactive Toggle Button (T&amp;C).</w:t></w:r></w:p><w:p w14:paraId="1CF8B01C" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Description:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> The "tap button" next to "Please accept the Terms and Conditions to continue" is a physical switch/toggle.</w:t></w:r></w:p><w:p w14:paraId="0B88D6C6" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>Action:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> When a user taps/clicks, the switch must slide from the "off" (dark/left) to the "on" (green/right) position with a smooth animation. This acceptance is required to enable the "Login" or "Sign-up" buttons.</w:t></w:r></w:p><w:p w14:paraId="1BA4310A" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Requirement FR-04: Button Actions.</w:t></w:r></w:p><w:p w14:paraId="04FA0E93" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Login Button:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="006C51EE"><w:t>Authenticats</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> user, leading to the dashboard. Disabled until T&amp;C accepted.</w:t></w:r></w:p><w:p w14:paraId="080DCAE3" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Sign-up Button:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Initiates new user creation. Disabled until T&amp;C accepted.</w:t></w:r></w:p><w:p w14:paraId="142D23C2" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>5.2 Real-Time Dashboard (Based on Image 1)</w:t></w:r></w:p><w:p w14:paraId="22C19348" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Requirement FR-05: Real-Time Data Fetching.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> The dashboard must update data every [X seconds, e.g., 5 seconds] via a reliable communication channel (e.g., </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="006C51EE"><w:t>WebSockets</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="006C51EE"><w:t>, MQTT).</w:t></w:r></w:p><w:p w14:paraId="773C07C5" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Requirement FR-06: Measurement Modules (Frosted Glass Style).</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Each key metric must be displayed in a distinct, styled container.</w:t></w:r></w:p><w:p w14:paraId="55030FDE" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Voltage:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Range (e.g., 100V-250V), specific value (e.g., "120.5 V"), with a thunderbolt icon.</w:t></w:r></w:p><w:p w14:paraId="7184A8DD" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Current:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Range (e.g., 0A-30A), specific value (e.g., "2.3 A"), with an ammeter icon.</w:t></w:r></w:p><w:p w14:paraId="094F11BC" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Power:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> specific value (e.g., "277.15 W"), with a lightbulb icon.</w:t></w:r></w:p><w:p w14:paraId="39681F0E" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Energy:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> specific value (e.g., "997,740 J"), with a battery icon.</w:t></w:r></w:p><w:p w14:paraId="6A7C3A0B" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Bill:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> calculated value (e.g., "₹ 14.50"), with a stack of currency icon.</w:t></w:r></w:p><w:p w14:paraId="3ACBAFA8" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Requirement FR-07: Load Control Buttons.</w:t></w:r></w:p><w:p w14:paraId="331E9CF2" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Description:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> An interactive panel with "Load," "ON," and "OFF" text.</w:t></w:r></w:p><w:p w14:paraId="3877AC62" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Action:</w:t></w:r></w:p><w:p w14:paraId="621CF57B" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="2"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:t>Tapping/Clicking "ON" (green) sends a signal to turn the remote load ON. The green state should visually confirm the action.</w:t></w:r></w:p><w:p w14:paraId="0C024D46" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="2"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:t>Tapping/Clicking "OFF" (darker) sends a signal to turn the remote load OFF. The visual state should reflect the OFF status.</w:t></w:r></w:p><w:p w14:paraId="4F5B24E2" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Requirement FR-08: Environmental Monitoring.</w:t></w:r></w:p><w:p w14:paraId="76A2E39D" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Temperature:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> specific value (e.g., "24.5 °C"), with a thermometer icon.</w:t></w:r></w:p><w:p w14:paraId="6203055B" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Humidity:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> specific value (e.g., "58 %"), with a water drop icon.</w:t></w:r></w:p><w:p w14:paraId="28F14FB3" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>5.3 Calculation Logic</w:t></w:r></w:p><w:p w14:paraId="4C8B3F1F" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>Requirement FR-09: Power Calculation.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Instantaneous Power () = Voltage () × Current () × Power Factor (assumed 1.0 or to be sourced from hardware).</w:t></w:r></w:p><w:p w14:paraId="150171D7" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Requirement FR-10: Energy Accumulation.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Energy () = .</w:t></w:r></w:p><w:p w14:paraId="7378F5F5" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Requirement FR-11: Bill Calculation.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Bill () = (Total Energy Consumption (kWh) × Rate per kWh) + Fixed Charges.</w:t></w:r></w:p><w:p w14:paraId="0280A255" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>Need to convert Joules to kWh: 1 kWh = 3,600,000 Joules.</w:t></w:r></w:p><w:p w14:paraId="1BE040C4" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>Configurable rate structure is a must.</w:t></w:r></w:p><w:p w14:paraId="0521674A" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>6. User Interface (UI) and Experience (UX)</w:t></w:r></w:p><w:p w14:paraId="6D844252" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="8"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>UI-01: Theme.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Serene, "forest morning" feel. Mint-green header, transitioning to deep evergreen for the lower section. Background illustration of misty pine trees is critical.</w:t></w:r></w:p><w:p w14:paraId="05F125B9" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="8"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>UI-02: Modular Design.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Core metrics are displayed in elegant, translucent "frosted glass" containers with clean, dark-green borders and a soft blur effect, allowing the background forest to remain visible.</w:t></w:r></w:p><w:p w14:paraId="0F40ED45" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="8"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>UI-03: Icons.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> High-quality, illustrative icons for each metric (thunderbolt, ammeter, lightbulb, battery, currency, thermometer, water drop) to enhance recognition.</w:t></w:r></w:p><w:p w14:paraId="48DB3959" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="8"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>UI-04: Button Style.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Rounded rectangular buttons, matching the nature </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="006C51EE"><w:t>color</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> palette (green for login/on, light green for sign-up, dark green for off).</w:t></w:r></w:p><w:p w14:paraId="1D33D789" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>7. Non-Functional Requirements</w:t></w:r></w:p><w:p w14:paraId="68E07231" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>7.1 Performance</w:t></w:r></w:p><w:p w14:paraId="0589B053" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="9"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>NFR-01: Latency.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Real-time data updates from the smart meter to the dashboard should have a latency of less than 2 seconds.</w:t></w:r></w:p><w:p w14:paraId="0E3E108F" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="9"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>NFR-02: Scalability.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> The platform should handle at least [X,000] concurrent users and devices without noticeable performance degradation.</w:t></w:r></w:p><w:p w14:paraId="7E0DFE76" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>7.2 Data &amp; Security</w:t></w:r></w:p><w:p w14:paraId="79E7DDC3" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="10"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>NFR-03: Encryption.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> All data transmission (username, password, meter data) must be encrypted using standard protocols (e.g., HTTPS, SSL/TLS).</w:t></w:r></w:p><w:p w14:paraId="4F338D6E" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="10"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>NFR-04: User Privacy.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Personal data must be handled according to strict privacy guidelines (e.g., GDPR, CCPA).</w:t></w:r></w:p><w:p w14:paraId="07C59E17" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>7.3 Reliability</w:t></w:r></w:p><w:p w14:paraId="434E85C3" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="11"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>NFR-05: System Uptime.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> The web application should aim for [99.9%] uptime.</w:t></w:r></w:p><w:p w14:paraId="366E6687" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="11"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>NFR-06: Data Integrity.</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Ensure meter readings are accurately transmitted and stored without data loss or corruption.</w:t></w:r></w:p><w:p w14:paraId="446016F8" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>7.4 Compliance</w:t></w:r></w:p><w:p w14:paraId="355DFE56" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="12"/></w:numPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>NFR-07:</w:t></w:r><w:r w:rsidRPr="006C51EE"><w:t xml:space="preserve"> Adhere to any relevant national or regional standards for smart metering data handling and privacy.</w:t></w:r></w:p><w:p w14:paraId="71F305B3" w14:textId="77777777" w:rsidR="006C51EE" w:rsidRPr="006C51EE" w:rsidRDefault="006C51EE" w:rsidP="006C51EE"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006C51EE"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>8. Development Timeline and Milestones</w:t></w:r></w:p><w:p w14:paraId="39057B04" w14:textId="132EA9C7" w:rsidR="00890B2B" w:rsidRDefault="00890B2B"/><w:sectPr w:rsidR="00890B2B"><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/><w:cols w:space="708"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>